PORT = 3000
HOST = localhost

# --- Base de datos: LOCAL (desarrollo) ---
MONGODB_URI = mongodb://127.0.0.1:27017
MONGODB_DB_NAME = tienda-sol

# --- Base de datos: PRODUCCION (MongoDB Atlas) ---
# Descomentá y completá esta linea para usar Atlas. Tiene prioridad sobre las dos de arriba.
# Incluí el nombre de la base (/tienda-sol) antes del "?".
# MONGODB_CONNECTION_STRING = mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/tienda-sol?retryWrites=true&w=majority

JWT_SECRET = secreto-super-secreto
JWT_EXPIRES_IN = 1d
FRONTEND_URL = http://localhost:3001
NODE_ENV = development
